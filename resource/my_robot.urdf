<?xml version="1.0" ?>
<robot name="my_robot">
    <webots>
        <plugin type="enpm701_simulation.my_robot_driver.MyRobotDriver" />
        <device reference="camera" type="Camera">
            <ros>
                <alwaysOn>true</alwaysOn>
            </ros>
        </device>
    </webots>
</robot>